---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');
const sorted = allDocs.sort((a, b) => a.data.sidebar_position - b.data.sidebar_position);
const firstDoc = sorted[0];
---

<Layout title="XCSoar Docs">
  <div class="min-h-screen bg-gradient-to-br from-slate-50 to-sky-50 flex flex-col items-center justify-center px-6 text-center">
    <div class="max-w-2xl">
      <div class="mb-6 flex justify-center">
        <svg class="w-14 h-14 text-sky-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
      </div>
      <h1 class="text-5xl font-bold text-slate-900 mb-4">XCSoar Docs</h1>
      <p class="text-xl text-slate-500 mb-10 leading-relaxed">
        The complete pilot's manual for XCSoar — an open-source glide computer for soaring flight.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`/docs/${firstDoc.id}`}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-sky-600 text-white font-medium hover:bg-sky-700 transition-colors shadow-sm"
        >
          Get Started
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </a>
        <a
          href="/docs/installation"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-slate-200 bg-white text-slate-700 font-medium hover:border-slate-300 hover:bg-slate-50 transition-colors"
        >
          Installation Guide
        </a>
      </div>

      <div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-6 text-left">
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
          <div class="w-8 h-8 bg-sky-100 rounded-lg flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-1">Navigation</h3>
          <p class="text-sm text-slate-500">Moving map, waypoints, and cross-country task management</p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
          <div class="w-8 h-8 bg-sky-100 rounded-lg flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-1">Glide Computer</h3>
          <p class="text-sm text-slate-500">MacCready theory, thermal detection, and glide calculations</p>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
          <div class="w-8 h-8 bg-sky-100 rounded-lg flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-1">Configuration</h3>
          <p class="text-sm text-slate-500">Device setup, avionics integration, and customization</p>
        </div>
      </div>

      <p class="mt-10 text-sm text-slate-400">
        {sorted.length} chapters · Open source ·
        <a href="https://xcsoar.org" target="_blank" rel="noopener" class="text-sky-500 hover:text-sky-700">xcsoar.org</a>
      </p>
    </div>
  </div>
</Layout>
