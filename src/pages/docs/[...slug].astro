---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const GITHUB_BASE = 'https://github.com/XCSoar/XCSoar/blob/master/doc/manual/en';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  const sorted = entries.sort((a, b) => a.data.sidebar_position - b.data.sidebar_position);

  return sorted.map((entry, index) => {
    const prev = sorted[index - 1] ?? null;
    const next = sorted[index + 1] ?? null;
    return {
      params: { slug: entry.id },
      props: {
        entry,
        prevPage: prev ? { slug: prev.id, title: prev.data.title, sidebar_position: prev.data.sidebar_position } : null,
        nextPage: next ? { slug: next.id, title: next.data.title, sidebar_position: next.data.sidebar_position } : null,
      },
    };
  });
}

const { entry, prevPage, nextPage } = Astro.props;
const { Content, headings } = await render(entry);

const editUrl = `${GITHUB_BASE}/${entry.id}.tex`;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<DocsLayout
  title={entry.data.title}
  currentSlug={entry.id}
  prevPage={prevPage}
  nextPage={nextPage}
  editUrl={editUrl}
  headings={tocHeadings}
>
  <Content />
</DocsLayout>
